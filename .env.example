# ── Contact enrichment ───────────────────────────────────────────────────────

# Enable the /api/enrich-contact endpoint
CONTACT_ENRICHMENT_ENABLED=true

# Provider selection — 'snov' is the only implemented provider
# Set to 'hunter' once lib/contactProviders/hunter.ts is implemented
CONTACT_PROVIDER=snov

# Snov.io credentials (required when CONTACT_PROVIDER=snov)
SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=

# ── Durable store (required in production) ────────────────────────────────────

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Security ──────────────────────────────────────────────────────────────────

# Secret for signing admin session cookies. Generate with: openssl rand -hex 32
# Required in production.
SESSION_SECRET=

# Random 32+ byte hex string — used to HMAC-pseudonymize all audit log identifiers
# and Redis key names. NEVER log this value. Required in production.
LOG_HASH_SECRET=

# Admin-only access token for the enrichment endpoint.
# Replace with proper session/JWT auth before public launch.
# Required in production — fail closed if absent.
CONTACT_ENRICHMENT_ADMIN_TOKEN=

# App URL for Origin header validation (required in production)
NEXT_PUBLIC_APP_URL=https://yourapp.com

# ── Optional ──────────────────────────────────────────────────────────────────

# Global daily provider credit budget (default: 500)
ENRICHMENT_DAILY_BUDGET=500

# ── Availability token + scheduling ──────────────────────────────────────────

# HMAC secret for signed availability tokens.
# Generate with: openssl rand -hex 32
# Must be at least 32 hex characters. Required in production.
AVAILABILITY_TOKEN_SECRET=

# HMAC secret for signed signup/invite tokens.
# Generate with: openssl rand -hex 32
# Must be at least 32 hex characters. Required in production.
SIGNUP_TOKEN_SECRET=

# Resend API key for sending availability request emails (required)
# Get yours at https://resend.com
RESEND_API_KEY=

# "From" address for availability request emails (required)
# Format: "Display Name <address@example.com>"
# Domain must be verified in your Resend account.
OUTREACH_FROM_EMAIL="ExpertMatch <outreach@yourdomain.com>"

# ── Google Calendar OAuth ─────────────────────────────────────────────────────

# OAuth 2.0 credentials from Google Cloud Console.
# Redirect URI to register: https://yourapp.com/api/availability/oauth/google/callback
# Scopes required: https://www.googleapis.com/auth/calendar.freebusy
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AES-256-GCM key for encrypting OAuth tokens at rest.
# Generate with: openssl rand -hex 32
# Must be exactly 64 hex characters. Required in production.
ENCRYPTION_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────────

# Get from dashboard.stripe.com → Developers → API keys
# Use sk_test_... for development, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret from: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Google Calendar invite creation ──────────────────────────────────────────

# Refresh token for the app's own Google Calendar (creates event invites).
# One-time setup: visit /api/admin/google-calendar-auth while logged in,
# complete the OAuth flow, and copy the logged refresh_token here.
# Scope required: https://www.googleapis.com/auth/calendar.events
GOOGLE_CALENDAR_REFRESH_TOKEN=

# ── Zoom Server-to-Server OAuth ───────────────────────────────────────────────

# Create at marketplace.zoom.us → Develop → Build App → Server-to-Server OAuth
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Zoom webhook secret token
# Set in Zoom App → Feature → Event Subscriptions → Secret Token
ZOOM_WEBHOOK_SECRET_TOKEN=

# ── OpenAI ────────────────────────────────────────────────────────────────────

# Get from platform.openai.com/api-keys
OPENAI_API_KEY=
